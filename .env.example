# 真實機票／住宿價格（選用）。在 Vercel 專案 → Settings → Environment Variables 設定。
# 不設定時，網站照常用「示範估價」（依市場行情模擬），完全不影響運作。
#
# 這些是「伺服器端」變數（給 /api/* serverless functions 用），不會打包進前端、不會外洩。
# 本機 npm run dev 不會跑 serverless，所以本機一律顯示示範估價；正式環境（Vercel）才會生效。

# 選擇 provider：travelpayouts 或 amadeus（留空＝停用，用示範估價）
PRICE_PROVIDER=

# ---- Travelpayouts（一個帳號 = 機票 Aviasales + 飯店 Hotellook + Booking/Agoda/Trip 分潤）----
# 註冊：https://www.travelpayouts.com/  → 取得 API token
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# ---- Amadeus Self-Service（官方免費 tier，真實機票/飯店 offer）----
# 註冊：https://developers.amadeus.com/  → 建立 App 取得 API Key / Secret
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test
